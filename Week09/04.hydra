voronoi(20, 0.1, 3)
  .add(osc(2, 0.1, 0.5))
  .kaleid(20)
  .colorama(0.02)
  .out(o1)


noise(4, 0.1)
  .mult(osc(3, 0.1, 1))
  .kaleid(6)
  .colorama(0.01)
  .out(o2)


src(o1)
  .add(src(o2), 0.5)
  .modulateRotate(o1, 0.5)
  .mult(src(o1).modulateScale(o2, 0.3), 0.8)
  .scale(1, 1, 2)
  .out(o0)

render(o0)
